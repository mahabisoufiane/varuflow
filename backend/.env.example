# File: .env.example
# Purpose: Template for local .env — copy to .env and fill in real values
# Used by: local development (docker compose), never committed with real values

# PostgreSQL — asyncpg driver required. Railway/Supabase supply postgresql://, add +asyncpg manually.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# Comma-separated origins — NO JSON brackets, NO spaces around commas
# Local:       CORS_ORIGINS=http://localhost:3000
# Production:  CORS_ORIGINS=https://varuflow.vercel.app
# Both:        CORS_ORIGINS=https://varuflow.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
OPENAI_API_KEY=
PORTAL_JWT_SECRET=change-me-to-32-random-chars-in-prod
PORTAL_BASE_URL=https://varuflow.vercel.app
FRONTEND_URL=https://varuflow.vercel.app
SENTRY_DSN=
ENV=development
DEBUG=true
