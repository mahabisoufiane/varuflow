# File: .env.example
# Purpose: Template for local .env — copy to .env and fill in real values
# Used by: local development (docker compose), never committed with real values

# PostgreSQL — asyncpg driver required. Railway/Supabase supply postgresql://, add +asyncpg manually.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# Comma-separated origins — NO JSON brackets, NO spaces around commas
# Local:       CORS_ORIGINS=http://localhost:3010
# Production:  CORS_ORIGINS=https://varuflow.vercel.app
# Both:        CORS_ORIGINS=https://varuflow.vercel.app,http://localhost:3010
CORS_ORIGINS=http://localhost:3010

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
OPENAI_API_KEY=
PORTAL_JWT_SECRET=change-me-to-32-random-chars-in-prod
PORTAL_BASE_URL=https://varuflow.vercel.app
FRONTEND_URL=https://varuflow.vercel.app
SENTRY_DSN=
ENV=development
DEBUG=true

# ── Standalone local auth ──────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_JWT_SECRET=change-me-use-64-char-random-hex-in-production

# SMTP — leave SMTP_HOST blank to print emails to stdout in dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@varuflow.se

# ── Runtime hardening ──────────────────────────────────────────────────────
# True when the app sits behind a load balancer that injects X-Forwarded-For
# (Railway, Render, Fly). Leave False for direct-exposed deployments so the
# rate limiter uses request.client.host and cannot be spoofed.
TRUST_PROXY=false

# Fallback country when no header/subdomain/org country is resolved.
DEFAULT_COUNTRY=SE
